# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.  (.env 는 절대 공유 금지)
# 복사:  copy .env.example .env

# 필수 — Claude API 키
ANTHROPIC_API_KEY=sk-ant-여기에_키
CLAUDE_MODEL=claude-sonnet-5

# 선택 — 이미지(Unsplash)
UNSPLASH_ACCESS_KEY=

# 네이버 블로그
NAVER_BLOG_ID=trend_claude

# 선택 — 네이버 검색광고 API (실제 검색량 키워드)
#   https://searchad.naver.com → 도구 → API 사용관리 에서 발급
NAVER_AD_API_KEY=
NAVER_AD_SECRET=
NAVER_AD_CUSTOMER_ID=

# 선택 — 네이버 검색 API (제목 유사성 체크)
#   https://developers.naver.com/apps → 애플리케이션 등록 → '검색' 추가
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
